# ── 필수 ──────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname
JWT_SECRET=여기에_랜덤_문자열_입력

# ── 초기 관리자 계정 (처음 배포 시 1회만 적용) ────────
ADMIN_EMAIL=admin@yourteam.com
ADMIN_PASSWORD=바꿔야할비밀번호!
ADMIN_NAME=관리자

# ── 초기 팀원 계정 (선택사항) ─────────────────────────
# 형식: "이름1:비밀번호1,이름2:비밀번호2"
# 비밀번호 생략 시 SEED_PASSWORD 사용
# SEED_MEMBERS=홍길동:pass1234,김철수:pass1234
# SEED_PASSWORD=loom1234!

# ── 서버 ──────────────────────────────────────────────
NODE_ENV=production
PORT=8080
